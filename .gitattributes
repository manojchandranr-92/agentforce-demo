# Attachments tracked via Git LFS
**/attachments/** filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
*.docx filter=lfs diff=lfs merge=lfs -text
*.xlsx filter=lfs diff=lfs merge=lfs -text

# Markdown uses union merge driver: keeps both sides when conflicts occur,
# so auto-merge succeeds even on overlapping edits. A downstream cleanup
# pass can de-dupe if needed.
*.md merge=union

# YAML files merge normally - conflicts here are usually meaningful and
# deserve human review.
